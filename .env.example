# ─────────────────────────────────────────────────────────
# WalletDNA — Environment Configuration
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Base Network RPC URL (get free key at https://alchemy.com)
BASE_RPC_URL=https://mainnet.base.org

# Server Configuration
PORT=3001
BASE_URL=https://your-railway-domain.up.railway.app
PUBLIC_APP_URL=https://your-railway-domain.up.railway.app

# VITE_API_URL — only needed for local development if the dev proxy target
# differs from the default (http://localhost:3001). In production, the frontend
# and backend share the same Railway domain, so all /api/... requests are
# served directly by the Express backend — no proxy or absolute URL required.
# VITE_API_URL=http://localhost:3001

# JWT Secret — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-random-secret

# Admin token — protects admin endpoints
# Generate with: openssl rand -base64 24
ADMIN_TOKEN=replace-with-admin-token

# Support Email (shown in UI)
SUPPORT_EMAIL=support@walletdna.app
VITE_SUPPORT_EMAIL=support@walletdna.app

# Gumroad Configuration (from your Gumroad dashboard)
GUMROAD_PRODUCT_ID=
GUMROAD_WEBHOOK_SECRET=

# Database path (SQLite)
DATABASE_PATH=./alpha_engine.db

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BROADCAST_BOT_TOKEN=
BROADCAST_CHANNEL_ID=
